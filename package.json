{
  "name": "roam-gtd",
  "version": "0.1.0",
  "private": true,
  "description": "GTD dashboard and weekly review wizard for Roam Research",
  "license": "MIT",
  "scripts": {
    "build:roam": "samepage build && mkdir -p build && cp extension.js build/extension.js && pnpm smoke:build-artifact",
    "serve:roam-dev": "node scripts/serve-roam-dev.mjs",
    "smoke:build-artifact": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/smoke-build-artifact.mjs",
    "start": "samepage dev",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --disable-nested-config",
    "lint:fix": "oxlint --disable-nested-config --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "run-p check:*",
    "check:lint": "oxlint --disable-nested-config",
    "check:format": "oxfmt --check .",
    "check:types": "tsgo --noEmit",
    "check:test": "vitest run --coverage"
  },
  "dependencies": {
    "chrono-node": "^2.9.0",
    "roamjs-components": "^0.82.0"
  },
  "devDependencies": {
    "@nkzw/eslint-plugin": "^2.0.0",
    "@nkzw/oxlint-config": "^1.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@vitest/coverage-v8": "3.2.4",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "20.0.3",
    "lefthook": "^1.10.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  },
  "roam-depot": {
    "source-repo": "https://github.com/roam-gtd/roam-gtd",
    "source-url": "https://github.com/roam-gtd/roam-gtd/releases/download/${VERSION}/extension.js"
  },
  "samepage": {
    "extends": "node_modules/roamjs-components/package.json",
    "review": ""
  },
  "tags": [
    "automations",
    "todos",
    "gtd"
  ]
}
